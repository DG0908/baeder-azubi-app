# ─── Datenbank ─────────────────────────────────────────────
POSTGRES_DB=azubi_app
POSTGRES_USER=azubi_app
POSTGRES_PASSWORD=change_me_to_a_long_random_password
DATABASE_URL=postgresql://azubi_app:change_me_to_a_long_random_password@postgres:5432/azubi_app?schema=public

# ─── Server ───────────────────────────────────────────────
WEB_BIND_ADDRESS=0.0.0.0
WEB_PORT=80
APP_PORT=3000
APP_CORS_ORIGINS=https://azubi.smartbaden.de
APP_COOKIE_DOMAIN=
APP_COOKIE_SECURE=true
APP_PUBLIC_URL=https://azubi.smartbaden.de
NODE_ENV=production
LOG_LEVEL=log,warn,error
PRISMA_SLOW_QUERY_THRESHOLD_MS=500

# ─── Auth / JWT ───────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_at_least_32_characters
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=replace_with_at_least_32_characters
JWT_REFRESH_TTL=7d
INVITATION_CODE_PEPPER=replace_with_at_least_32_characters
PASSWORD_RESET_TOKEN_PEPPER=replace_with_at_least_32_characters
PASSWORD_RESET_TTL=30m
APP_TOTP_ENCRYPTION_KEY=replace_with_at_least_32_characters

# ─── E-Mail (SMTP) ───────────────────────────────────────
SMTP_HOST=smtp.example.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.de
SMTP_PASSWORD=replace_with_a_real_secret
SMTP_FROM=mailer@example.de

# ─── Web Push ─────────────────────────────────────────────
# Generieren: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@example.de

# ─── Duell-System ─────────────────────────────────────────
DUEL_DEFAULT_QUESTION_COUNT=20
DUEL_REQUEST_TTL_MINUTES=2880
DUEL_TURN_TTL_MINUTES=2880

# ─── Frontend (VITE_*) ───────────────────────────────────
# Nur diese zwei werden im Frontend-Build gebraucht:
VITE_API_BASE_URL=/api/v1
VITE_WEB_PUSH_PUBLIC_KEY=

# ─── Optional: Sentry ────────────────────────────────────
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
