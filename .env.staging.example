# ─── Staging Environment ───────────────────────────────────
# Kopiere diese Datei als .env.staging und fuelle die Werte aus.
# WICHTIG: Eigene Secrets verwenden, NICHT die Produktion-Werte!

# ─── Datenbank ─────────────────────────────────────────────
POSTGRES_DB=azubi_staging
POSTGRES_USER=azubi_staging
POSTGRES_PASSWORD=change_me_staging_password
DATABASE_URL=postgresql://azubi_staging:change_me_staging_password@postgres-staging:5432/azubi_staging?schema=public

# ─── Server ───────────────────────────────────────────────
APP_PORT=3000
APP_CORS_ORIGINS=https://staging.azubi.smartbaden.de
APP_COOKIE_DOMAIN=
APP_COOKIE_SECURE=true
APP_PUBLIC_URL=https://staging.azubi.smartbaden.de
NODE_ENV=production
LOG_LEVEL=debug

# ─── Auth / JWT (eigene Secrets!) ────────────────────────
JWT_ACCESS_SECRET=staging_replace_with_at_least_32_characters
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=staging_replace_with_at_least_32_characters
JWT_REFRESH_TTL=7d
INVITATION_CODE_PEPPER=staging_replace_with_at_least_32_characters
PASSWORD_RESET_TOKEN_PEPPER=staging_replace_with_at_least_32_characters
PASSWORD_RESET_TTL=30m
APP_TOTP_ENCRYPTION_KEY=staging_replace_with_at_least_32_characters

# ─── E-Mail (SMTP) ───────────────────────────────────────
# Optional: Gleicher SMTP-Server, aber mit [STAGING]-Prefix in Mails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ─── Web Push ─────────────────────────────────────────────
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@example.de

# ─── Duell-System ─────────────────────────────────────────
DUEL_DEFAULT_QUESTION_COUNT=20
DUEL_REQUEST_TTL_MINUTES=2880
DUEL_TURN_TTL_MINUTES=2880

# ─── Frontend (VITE_*) ───────────────────────────────────
VITE_API_BASE_URL=/api/v1
VITE_WEB_PUSH_PUBLIC_KEY=
