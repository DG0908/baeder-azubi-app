    { q: 'Wofür wird HClO im Schwimmbad verwendet?', a: ['Zur Desinfektion des Beckenwassers', 'Zur Wassererwärmung über den Wärmetauscher', 'Zur pH-Wert-Erhöhung als Puffersubstanz', 'Zur Entfärbung und Trübungsbeseitigung'], correct: 0 },
