    { q: 'Wozu dient die Flockung des Rohwassers?', a: ['Zusammenlagerung feiner Partikel zu größeren Flocken für die Filtration', 'Nur zur Färbung des Wassers unter Aufsicht nach Desinfektionsplan', 'Zur Desinfektion bei Standardbedingungen im Rahmen der Eigenkontrolle', 'Zur Wassererwärmung nach Herstellervorgabe nach Trinkwasserverordnung'], correct: 0 },
    { q: 'Wodurch kann die Flockung beeinflusst werden?', a: ['pH-Wert, Dosierung, Mischung, Temperatur, Wasserchemie', 'Nur durch die Wassermenge nach Dienstanweisung', 'Nur durch die Farbe wie vorgeschrieben', 'Gar nicht beeinflussbar gemäß Prüfprotokoll'], correct: 0 },
    { q: 'Welche Flockungsmittel werden in der Bädertechnik eingesetzt?', a: ['Aluminiumsulfat, Eisen-III-Chlorid, Polyaluminiumchlorid', 'Nur Kochsalz gemäß Gefährdungsbeurteilung', 'Nur Chlor durch den Betreiber im Regelbetrieb', 'Nur Essig bei vorschriftsmäßigem Betrieb'], correct: 0 },
    { q: 'Welche Auswirkung hat Flockung mit Aluminiumsulfat auf das Rohwasser?', a: ['pH-Wert sinkt, Karbonathärte sinkt, Flocken bilden sich', 'pH-Wert steigt gemäß Betriebsanweisung', 'Keine Auswirkung durch Fachpersonal bei ordnungsgemäßem Betrieb', 'Wasser wird warm nach geltender Vorschrift'], correct: 0 },
    { q: 'Welche Auswirkung hat Flockung mit Natriumaluminat auf das Rohwasser?', a: ['pH-Wert steigt, Flocken bilden sich, alkalische Reaktion', 'pH-Wert sinkt stark und dokumentieren', 'Keine Auswirkung im Normalbetrieb bei ordnungsgemäßem Betrieb', 'Wasser gefriert nach technischer Regel'], correct: 0 },
    { q: 'Wie muss die Reaktionsstrecke bei der Flockung beschaffen sein?', a: ['Ausreichend lang für vollständige Flockenbildung, turbulente Mischung', 'Möglichst kurz nach Hygieneplan im Rahmen der Eigenkontrolle', 'Ohne Durchmischung im Regelbetrieb nach UVV in regelmäßigen Abständen', 'Egal wie lang nach aktueller Norm nach technischer Regel'], correct: 0 },
    { q: 'Welchen Sinn hat die Reaktionsstrecke bei der Flockung?', a: ['Zeit und Raum für die Reaktion des Flockungsmittels mit den Verunreinigungen', 'Nur Wassererwärmung bei Standardbedingungen durch den Betreiber', 'Nur Druckerhöhung nach Trinkwasserverordnung gemäß Infektionsschutzgesetz', 'Kein besonderer Sinn im laufenden Betrieb im Regelbetrieb'], correct: 0 },
    { q: 'Warum sollen Pumpen vor der Flockungsimpfstelle eingebaut sein?', a: ['Damit die Pumpe die Durchmischung des Flockungsmittels unterstützt', 'Aus Platzgründen gemäß Gefährdungsbeurteilung', 'Wegen der Optik nach Desinfektionsplan laut RKI-Empfehlung', 'Das ist nicht wichtig gemäß Infektionsschutzgesetz'], correct: 0 },
    { q: 'Wie werden Flockungsmittel eingeimpft?', a: ['Durch Dosierpumpen in die Rohwasserleitung nach der Umwälzpumpe', 'Per Hand ins Becken unter Betriebsbedingungen', 'Durch Schwerkraft nach aktueller Norm gemäß Gefährdungsbeurteilung', 'Durch Verdampfung im Normalbetrieb gemäß Prüfprotokoll'], correct: 0 },
    { q: 'Wie setzt sich Aluminiumsulfat (Al₂(SO₄)₃) chemisch zusammen?', a: ['Aus Aluminium, Schwefel und Sauerstoff', 'Aus Eisen und Chlor nach Desinfektionsplan', 'Aus Natrium und Chlor nach technischer Regel', 'Aus Calcium und Kohlenstoff'], correct: 0 },
    { q: 'Was passiert chemisch bei Einsatz von Eisen-III-Chlorid im Wasser?', a: ['Es bilden sich Eisen(III)-hydroxid-Flocken unter pH-Absenkung', 'Das Wasser wird rot im laufenden Betrieb', 'Nichts passiert nach Desinfektionsplan und dokumentieren', 'Das Wasser gefriert nach DIN 19643 gemäß Betriebsanweisung'], correct: 0 },
    { q: 'Welche chemische Formel hat Aluminiumsulfat?', a: ['Al₂(SO₄)₃', 'FeCl₃', 'NaCl', 'CaCO₃'], correct: 0 },
    { q: 'Welche chemische Formel hat Eisen-III-Sulfat?', a: ['Fe₂(SO₄)₃', 'Al₂(SO₄)₃', 'FeCl₃', 'NaOH'], correct: 0 },
    { q: 'Wovon ist eine optimale Flockung abhängig?', a: ['Richtige Dosierung, geeigneter pH-Wert, gute Durchmischung', 'Nur von der Wassertemperatur durch geschultes Personal', 'Nur vom Wasserdruck gemäß Infektionsschutzgesetz', 'Von nichts Besonderem in regelmäßigen Abständen'], correct: 0 },
    { q: 'Welche Aufgaben hat ein Marmorreaktionsturm?', a: ['Entsäuerung des Wassers und Einstellung des Kalk-Kohlensäure-Gleichgewichts', 'Nur Wassererwärmung in regelmäßigen Abständen gemäß Infektionsschutzgesetz', 'Nur Filtration gemäß Betriebsanweisung gemäß Gefährdungsbeurteilung', 'Nur Desinfektion laut RKI-Empfehlung bei korrekter Anwendung'], correct: 0 },
    { q: 'Wie kann man Schwimmbadwasser chemisch enthärten?', a: ['Durch Zugabe von Enthärtungsmitteln (Phosphate, Komplexbildner)', 'Durch Erhitzen nach geltender Vorschrift gemäß Gefährdungsbeurteilung', 'Durch Abkühlen bei ordnungsgemäßem Betrieb', 'Gar nicht möglich nach technischer Regel bei korrekter Anwendung'], correct: 0 },
    { q: 'Wie kann man Schwimmbadwasser technologisch enthärten?', a: ['Durch Ionenaustauscher oder Umkehrosmose', 'Nur durch Kochen bei Standardbedingungen', 'Nur durch Einfrieren nach Vorschrift', 'Nur durch Filtration laut RKI-Empfehlung'], correct: 0 },
    { q: 'Wann ist in der Wasseraufbereitung eine pH-Korrektur nötig?', a: ['Wenn der pH-Wert außerhalb des Sollbereichs (6,5-7,6) liegt', 'Nie nach Wartungsplan nach geltender Vorschrift', 'Nur einmal pro Jahr nach Dienstanweisung', 'Nur bei Neubefüllung nach Desinfektionsplan'], correct: 0 },
    { q: 'Welche Mittel werden zur pH-Korrektur eingesetzt?', a: ['Salzsäure/Schwefelsäure (Senkung), Natronlauge/Soda (Erhöhung)', 'Nur Kochsalz im laufenden Betrieb laut Betriebshandbuch', 'Nur Zucker nach technischer Regel und dokumentieren', 'Nur destilliertes Wasser gemäß Prüfprotokoll'], correct: 0 },
    { q: 'Warum muss die Säurekapazität des Wassers eingestellt werden?', a: ['Für ein stabiles Kalk-Kohlensäure-Gleichgewicht und stabile pH-Pufferung', 'Nur aus optischen Gründen unter Aufsicht bei korrekter Anwendung', 'Für die Wasserfarbe laut Herstellerangaben nach Betriebsvorschrift', 'Ist nicht nötig im Rahmen der Eigenkontrolle nach Vorschrift'], correct: 0 },
    { q: 'Wie kann man eine zu hohe Säurekapazität senken?', a: ['Durch Säurezugabe (z.B. Salzsäure, Schwefelsäure)', 'Durch Laugenzugabe nach Vorschrift', 'Durch Erwärmung gemäß Betriebsanweisung', 'Durch Chlorzugabe im Regelbetrieb'], correct: 0 },
    // Desinfektion Beckenwasser (Fragen 381-396)
    { q: 'Welche Anforderungen werden an Beckenwasserdesinfektionsmittel gestellt?', a: ['Breitspektrum-Wirkung, Depotwirkung, verträglich, DIN-zugelassen', 'Nur günstig gemäß Betriebsanweisung nach Hygieneplan', 'Nur gut riechend unter Aufsicht nach technischer Regel', 'Keine Anforderungen im laufenden Betrieb im Routinebetrieb'], correct: 0 },
    { q: 'Welche Desinfektionsmittel sind nach DIN 19643 für Beckenwasser erlaubt?', a: ['Chlorgas, Natriumhypochlorit, Calciumhypochlorit, Chlorelektrolyse, Ozon', 'Nur Chlorgas durch den Betreiber im laufenden Betrieb', 'Nur Ozon in regelmäßigen Abständen durch Fachpersonal', 'Beliebige Mittel gemäß Gefährdungsbeurteilung gemäß Betriebsanweisung'], correct: 0 },
    { q: 'Warum kann die Chlordosierung im Freibad bis 5x höher sein als im Hallenbad?', a: ['UV-Strahlung baut Chlor ab, höhere Verschmutzung durch Umwelteinflüsse', 'Weil Freibäder größer sind laut Herstellerangaben', 'Weil das Wasser kälter ist nach UVV bei vorschriftsmäßigem Betrieb', 'Das stimmt nicht durch geschultes Personal im Rahmen der Eigenkontrolle'], correct: 0 },
    { q: 'Welche Eigenschaften hat Chlor?', a: ['Gelbgrünes, giftiges Gas, schwerer als Luft, stechend riechend', 'Farbloses, geruchloses Gas im Regelbetrieb', 'Leichter als Luft nach DIN 19643 nach Trinkwasserverordnung', 'Ungiftig und geruchlos bei korrekter Anwendung'], correct: 0 },
    { q: 'Welche Eigenschaften hat Ozon?', a: ['Starkes Oxidationsmittel, instabil, zerfällt zu Sauerstoff, stechend riechend', 'Stabiles Gas im Routinebetrieb nach Hygieneplan nach Desinfektionsplan', 'Geruchlos laut Betriebshandbuch im Normalbetrieb durch den Betreiber', 'Schwächer als Chlor bei ordnungsgemäßem Betrieb nach Wartungsplan'], correct: 0 },
    { q: 'Welche Eigenschaften hat Natriumhypochlorit?', a: ['Flüssiges Desinfektionsmittel, alkalisch, chlorhaltig, begrenzt lagerfähig', 'Festes Pulver nach Trinkwasserverordnung im Normalbetrieb', 'Geruchlos und neutral durch den Betreiber gemäß Gefährdungsbeurteilung', 'Unbegrenzt haltbar bei vorschriftsmäßigem Betrieb'], correct: 0 },
    { q: 'Welche Chlorelektrolyseverfahren gibt es?', a: ['Salzsäure-Elektrolyse, Rohrzellen-Verfahren, Membranverfahren, Salzwasser-Elektrolyse', 'Nur ein Verfahren nach technischer Regel nach geltender Vorschrift', 'Nur manuelle Chlorung im Routinebetrieb nach Sicherheitsvorschrift', 'Keine Elektrolyseverfahren bei Standardbedingungen bei ordnungsgemäßem Betrieb'], correct: 0 },
    { q: 'Was passiert bei der Chlorelektrolyse?', a: ['Chlorid-Ionen werden durch Strom zu Chlor oxidiert', 'Wasser wird zu Dampf nach technischer Regel', 'Salz wird zu Gold nach DIN 19643 bei ordnungsgemäßem Betrieb', 'Nichts Besonderes laut RKI-Empfehlung'], correct: 0 },
    { q: 'Was sind Ausgangsstoffe für die Chlorelektrolyse?', a: ['Salzsäure, Natriumchlorid-Lösung, Salzwasser', 'Nur reines Wasser nach Vorschrift', 'Nur Chlorgas im Normalbetrieb', 'Nur Natronlauge in regelmäßigen Abständen'], correct: 0 },
    { q: 'Wie funktioniert die Elektrolyse von Salzsäure?', a: ['HCl wird durch Gleichstrom in Chlor (Cl₂) und Wasserstoff (H₂) zerlegt', 'HCl wird erhitzt nach Herstellervorgabe durch den Betreiber', 'HCl wird eingefroren nach Wartungsplan nach Desinfektionsplan', 'HCl wird verdünnt gemäß Infektionsschutzgesetz'], correct: 0 },
    { q: 'Was ist das Rohrzellen-Elektrolyseverfahren?', a: ['Elektrolyse in einem rohrförmigen Reaktor mit Anode und Kathode', 'Filtration in Rohren laut Betriebshandbuch', 'Desinfektion durch UV-Rohre nach Wartungsplan', 'Pumpen in Rohrform wie vorgeschrieben bei Standardbedingungen'], correct: 0 },
    { q: 'Wie funktioniert das Membran-Elektrolyseverfahren?', a: ['Anoden- und Kathodenraum sind durch eine Membran getrennt', 'Ohne Membran nach geltender Vorschrift', 'Durch Verdampfung durch den Betreiber gemäß Gefährdungsbeurteilung', 'Durch Filtration nach Hygieneplan durch Fachpersonal'], correct: 0 },
    { q: 'Wie funktioniert das Salzwasser-Elektrolyseverfahren?', a: ['Meersalz wird im Wasser gelöst und durch Strom zu Chlor umgewandelt (anodische Oxidation)', 'Salz wird einfach ins Becken gestreut wie vorgeschrieben im Routinebetrieb', 'Salzwasser wird abgekocht bei vorschriftsmäßigem Betrieb durch Fachpersonal', 'Salzwasser wird eingefroren laut RKI-Empfehlung bei Standardbedingungen'], correct: 0 },
    { q: 'Wie funktioniert ein Vakuumchlorgasdosiergerät?', a: ['Chlorgas wird durch Unterdruck (Vakuum) aus der Flasche gesaugt und dem Wasser zugeführt', 'Chlorgas wird unter Druck eingepresst bei Standardbedingungen', 'Chlor wird erhitzt im Rahmen der Betriebsführung im Rahmen der Eigenkontrolle', 'Chlor wird abgekühlt nach UVV nach aktueller Norm bei korrekter Anwendung'], correct: 0 },
    { q: 'Wie entsteht unterchlorige Säure (HOCl)?', a: ['Chlor reagiert mit Wasser: Cl₂ + H₂O → HOCl + HCl', 'Durch Erhitzen von Chlor gemäß Prüfprotokoll', 'Durch Mischen von Salz und Essig', 'Durch UV-Bestrahlung unter Aufsicht'], correct: 0 },
    // Chlorgasanlagen (Fragen 397-419)
    { q: 'Was ist eine Treibwasserleitung?', a: ['Wasserleitung, die durch Unterdruck Chlorgas aus dem Dosiergerät ansaugt', 'Eine Abwasserleitung durch geschultes Personal im Rahmen der Betriebsführung', 'Eine Gasleitung im Rahmen der Eigenkontrolle nach Trinkwasserverordnung', 'Eine Heizungsleitung nach Betriebsvorschrift nach geltender Vorschrift'], correct: 0 },
    { q: 'Welchen Sinn haben Chlorflaschenhilfsventile?', a: ['Sicheres Absperren der Chlorflasche ohne direkten Kontakt zum Flaschenventil', 'Nur Dekoration durch Fachpersonal im Rahmen der Eigenkontrolle', 'Nur als Ersatzventil nach Hygieneplan im Regelbetrieb', 'Kein besonderer Sinn laut Betriebshandbuch bei vorschriftsmäßigem Betrieb'], correct: 0 },
    { q: 'Wie prüfen Sie Chlor führende Leitungen auf Dichtheit?', a: ['Mit Ammoniakdampf (weißer Nebel bei Chloraustritt) oder Lecksuchspray', 'Mit Wasser gemäß Gefährdungsbeurteilung im Normalbetrieb', 'Mit bloßem Auge nach Betriebsvorschrift nach Dienstanweisung', 'Gar nicht prüfbar nach Wartungsplan nach technischer Regel'], correct: 0 },
    { q: 'Wodurch kann eine Vereisung einer Chlorflasche entstehen?', a: ['Durch zu hohe Entnahmemenge – das expandierende Gas kühlt die Flasche stark ab', 'Durch zu warme Umgebung nach aktueller Norm nach Betriebsvorschrift', 'Durch Sonneneinstrahlung gemäß Prüfprotokoll durch geschultes Personal', 'Durch zu wenig Entnahme nach technischer Regel in regelmäßigen Abständen'], correct: 0 },
    { q: 'Welche Sicherheitsvorkehrungen treffen Sie beim Chlorgasflaschenwechsel?', a: ['Schutzausrüstung anlegen, Raum belüften, Chlorgaswarngerät prüfen, Ventile schließen', 'Keine besonderen Maßnahmen bei vorschriftsmäßigem Betrieb', 'Nur Fenster öffnen nach technischer Regel laut RKI-Empfehlung', 'Nur Handschuhe anziehen unter Aufsicht nach Dienstanweisung'], correct: 0 },
    { q: 'Wo befindet sich die Messzelle des Chlorgaswarngeräts?', a: ['In Bodennähe, da Chlorgas schwerer als Luft ist', 'An der Decke nach Herstellervorgabe', 'In der Mitte des Raums nach Desinfektionsplan', 'Außerhalb des Gebäudes nach DIN 19643'], correct: 0 },
    { q: 'Was ist der AGW-Wert für Chlor?', a: ['0,5 ppm (1,5 mg/m³)', '5 ppm durch Fachpersonal', '50 ppm laut Betriebshandbuch', '0,05 ppm nach Sicherheitsvorschrift'], correct: 0 },
    { q: 'Auf welchen Wert wird die Messzelle des Chlorgaswarngerätes eingestellt?', a: ['Auf den AGW-Wert (0,5 ppm) als Alarmschwelle', 'Auf 100 ppm nach aktueller Norm', 'Auf 0 ppm durch geschultes Personal', 'Auf keinen bestimmten Wert nach Trinkwasserverordnung'], correct: 0 },
    { q: 'Welche Bestimmungen gelten für Chlorgasanlagen?', a: ['Störfallverordnung, Unfallverhütungsvorschriften, TRG, TRGS', 'Keine besonderen Bestimmungen durch geschultes Personal', 'Nur interne Regeln gemäß Gefährdungsbeurteilung', 'Nur Empfehlungen im Normalbetrieb nach geltender Vorschrift'], correct: 0 },
    { q: 'Welche Sicherheitsbestimmungen gelten für Chlorgas-Lagerräume?', a: ['Belüftung, Gaswarnanlage, Berieselungsanlage, Bodenabfluss, feuerhemmende Tür', 'Keine besonderen Bestimmungen nach Sicherheitsvorschrift', 'Nur ein Schloss wie vorgeschrieben nach Herstellervorgabe', 'Nur ein Warnschild gemäß Prüfprotokoll bei Standardbedingungen'], correct: 0 },
    { q: 'Wie hoch ist die stündliche Entnahmemenge aus Chlorgasflaschen?', a: ['Max. ca. 500-700 g/h pro 50-kg-Flasche (um Vereisung zu vermeiden)', '10 kg/h laut RKI-Empfehlung im Routinebetrieb', '50 kg/h nach Sicherheitsvorschrift nach UVV', 'Unbegrenzt wie vorgeschrieben nach Wartungsplan'], correct: 0 },
    { q: 'Welchen Sinn hat die Berieselungsanlage im Chlorgasraum?', a: ['Bindung von austretendem Chlorgas durch Wasser im Havariefall', 'Nur Kühlung des Raums nach aktueller Norm', 'Nur Reinigung des Bodens durch Fachpersonal', 'Nur Brandschutz bei vorschriftsmäßigem Betrieb'], correct: 0 },
    { q: 'Wie gehen Sie mit vollen Chlorgasflaschen um?', a: ['Aufrecht transportieren, sichern, vor Hitze und Sonneneinstrahlung schützen', 'Beliebig rollen bei vorschriftsmäßigem Betrieb nach geltender Vorschrift', 'Werfen und stapeln durch den Betreiber nach Vorschrift', 'Ohne Vorsichtsmaßnahmen laut Betriebshandbuch nach UVV'], correct: 0 },
    { q: 'Wie gehen Sie mit leeren Chlorgasflaschen um?', a: ['Ventil schließen, Schutzkappen aufsetzen, als nicht leer behandeln', 'Einfach entsorgen nach technischer Regel und dokumentieren', 'Ventil offen lassen gemäß Gefährdungsbeurteilung', 'In den Müll werfen bei korrekter Anwendung nach aktueller Norm'], correct: 0 },
    { q: 'Was passiert, wenn Natriumhypochlorit mit Säuren in Kontakt kommt?', a: ['Es entsteht giftiges Chlorgas!', 'Nichts passiert wie vorgeschrieben', 'Es wird neutral bei vorschriftsmäßigem Betrieb', 'Es entsteht Sauerstoff'], correct: 0 },
    { q: 'Wie kann es zur Rückverflüssigung von Chlorgas kommen?', a: ['Durch Druckerhöhung oder starke Abkühlung in der Leitung', 'Durch Erwärmung im laufenden Betrieb nach Herstellervorgabe', 'Durch Verdünnung nach geltender Vorschrift', 'Gar nicht möglich wie vorgeschrieben laut RKI-Empfehlung'], correct: 0 },
    { q: 'Welche Aussagen lassen sich an der Dampfdruckkurve des Chlors ablesen?', a: ['Zusammenhang zwischen Temperatur und Druck für den Phasenübergang', 'Nur die Farbe des Chlors gemäß Prüfprotokoll', 'Nur das Gewicht in regelmäßigen Abständen nach Trinkwasserverordnung', 'Keine aussagekräftigen Daten nach UVV nach Dienstanweisung'], correct: 0 },
    { q: 'Wie viel Chlor darf man maximal pro Stunde aus einer 50-kg-Flasche entnehmen?', a: ['Ca. 500-700 g/h', '10 kg/h', '50 kg/h', '1 g/h'], correct: 0 },
    { q: 'In welchem Zustand befindet sich Chlor in der Chlorflasche?', a: ['Flüssig (unter Druck verflüssigt)', 'Gasförmig unter Betriebsbedingungen', 'Fest nach DIN 19643 nach Hygieneplan', 'Als Pulver bei vorschriftsmäßigem Betrieb'], correct: 0 },
    { q: 'In welchem Zustand befindet sich Chlor in der Dosierleitung?', a: ['Gasförmig (nach Expansion durch das Dosiergerät)', 'Flüssig nach DIN 19643 im Routinebetrieb', 'Fest bei vorschriftsmäßigem Betrieb', 'Als Pulver durch Fachpersonal gemäß Betriebsanweisung'], correct: 0 },
    { q: 'Was passiert, wenn die Temperatur an der Chlordosierleitung stark sinkt?', a: ['Chlorgas kann rückverflüssigen und die Dosierung unkontrolliert werden', 'Nichts passiert gemäß Gefährdungsbeurteilung im Normalbetrieb', 'Die Dosierung wird genauer laut RKI-Empfehlung', 'Das Chlor verdampft schneller durch Fachpersonal'], correct: 0 },
