    { q: 'Warum hat die Auftrittsfläche eines Startblocks 10% Neigung zum Becken?', a: ['Für einen optimalen Absprungwinkel beim Start', 'Damit Regenwasser und Spritzwasser besser abfließt', 'Aus optischen Gründen für ein besseres Erscheinungsbild', 'Gegen Rutschgefahr durch den Neigungswinkel'], correct: 0 },
    { q: 'Warum ist ein Sprungbrett ca. 2% zum Beckenumgang hin geneigt?', a: ['Damit Wasser vom Brett ablaufen kann und es rutschfester wird', 'Für besseren Absprungwinkel in Richtung Becken', 'Aus optischen Gründen für ein attraktiveres Aussehen', 'Das stimmt nicht – Sprungbretter sind immer waagerecht'], correct: 0 },
