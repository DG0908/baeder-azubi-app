    { q: 'Was sind typische Eigenschaften von Säuren?', a: ['Saurer Geschmack, pH < 7, ätzend, reagieren mit Metallen', 'Seifig, glatt, pH > 7 wie bei Laugen', 'Neutral, geschmacklos, pH = 7 wie destilliertes Wasser', 'Süß, klebrig, nicht reaktiv wie Zuckerlösungen'], correct: 0 },
    { q: 'Wobei spielen Säuren im Schwimmbadbereich eine wichtige Rolle?', a: ['pH-Wert-Korrektur und Desinfektion', 'Beheizung des Beckens über Wärmetauscher', 'Beleuchtung der Halle über elektrische Lichtquellen', 'Steuerung der Wellenmaschine und Pumpen'], correct: 0 },
    { q: 'Welche Säure wird zur pH-Wert-Senkung im Schwimmbad eingesetzt?', a: ['Salzsäure (HCl) oder Schwefelsäure (H₂SO₄)', 'Essigsäure (für Haushaltszwecke)', 'Zitronensäure (für Lebensmittel)', 'Kohlensäure (im Mineralwasser)'], correct: 0 },
    { q: 'Welche Sicherheitsmaßnahmen gelten beim Umgang mit Säuren?', a: ['Erst Säure auf Oberfläche geben, dann mit Wasser verdünnen', 'Nur Handschuhe – Schutzbrille ist unnötig bei verdünnten Säuren', 'Schutzbrille, Handschuhe, Schürze tragen; nie Wasser in Säure geben', 'Säuren können bedenkenlos mit Laugen gemischt werden'], correct: 2 },
