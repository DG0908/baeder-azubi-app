    // Schwallwasser & Messparameter (Fragen 73-81)
    { q: 'Was ist Verdrängungswasser?', a: ['Das aufbereitete Wasser, das aus der Filteranlage kommt', 'Das Wasser, das in der Überlaufrinne gesammelt wird', 'Das Rückspülwasser nach der Filterreinigung', 'Wasser, das durch den Körper des Badenden aus dem Becken verdrängt wird'], correct: 3 },
    { q: 'Was ist Schwallwasser?', a: ['Frisch aufbereitetes Wasser, das dem Becken zugeführt wird', 'Das Rückspülwasser nach der Filterreinigung', 'Das Filtrat nach dem Durchlauf durch den Filter', 'Durch Badende und Wellenbewegung über die Rinne abfließendes Wasser'], correct: 3 },
