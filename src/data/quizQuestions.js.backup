    { q: 'Was sind die reduzierenden Stoffe im Beckenwasser?', a: ['Verunreinigungen wie Harnstoff, Schweiß, Hautschuppen', 'Chlor und Ozon als Desinfektionsmittel', 'Nur gelöste Metallionen wie Eisen und Mangan', 'Nur Gase wie CO₂ und Sauerstoff'], correct: 0 },
    { q: 'Was sind die oxidierenden Stoffe im Beckenwasser?', a: ['Desinfektionsmittel wie Chlor oder Ozon', 'Nur Harnstoff aus dem Urin der Badegäste', 'Nur Hautschuppen und Körperfette', 'Nur Schweiß und Sonnencreme'], correct: 0 },
    { q: 'Wie wird das Redoxpotential gemessen?', a: ['Mit einer Redoxmesszelle (Platin-Elektrode gegen Bezugselektrode)', 'Mit einem Thermometer – Temperatur zeigt das Redoxpotential an', 'Mit einer Küvette und Farbindikatorlösung (DPD-Methode)', 'Mit einer Waage durch Wägen von Chlorproben'], correct: 0 },
    { q: 'Was besagt die Redox-Spannungsreihe?', a: ['Sie ordnet Metalle nach ihrem Bestreben, Elektronen abzugeben', 'Sie zeigt die Schmelztemperaturen verschiedener Metalle', 'Sie misst den Wasserdruck in verschiedenen Rohrleitungen', 'Sie zeigt die elektrische Leitfähigkeit von Lösungen'], correct: 0 },
    { q: 'Was ist Kalomel?', a: ['Quecksilber(I)-chlorid, verwendet als Bezugselektrode bei Redoxmessungen', 'Ein Filtermedium aus Quarzsand für Schnellfilter', 'Ein Chlordesinfektionsmittel für Beckenwasser', 'Eine Chlorverbindung zur pH-Wert-Absenkung'], correct: 0 },
    { q: 'Worüber gibt das Redoxpotential Auskunft?', a: ['Über den Filterrückspülbedarf der Anlage', 'Über den aktuellen Wasserstand im Schwallwasserbehälter', 'Über den Salzgehalt des Beckenwassers', 'Über das Verhältnis von oxidierenden zu reduzierenden Stoffen im Wasser'], correct: 3 },
    { q: 'Was sind Karbonathärtebildner des Wassers?', a: ['Calcium- und Magnesiumhydrogencarbonat', 'Natriumchlorid (Kochsalz)', 'Kaliumnitrat (Salpeter)', 'Eisensulfat (Eisen-II-sulfat)'], correct: 0 },
    { q: 'Wie setzt sich die Wasserhärte zusammen?', a: ['Aus Karbonathärte (temporär) und Nichtkarbonathärte (permanent)', 'Nur aus dem Kalkgehalt als Calciumcarbonat', 'Nur aus dem Salzgehalt des gelösten Natriumchlorids', 'Nur aus dem pH-Wert des Wassers'], correct: 0 },
    { q: 'Wodurch entsteht die Karbonathärte?', a: ['Durch gelöste Calcium- und Magnesiumhydrogencarbonate', 'Durch Chlorzugabe zur Wasserdesinfektion', 'Durch hohe Wassertemperaturen über 30°C', 'Durch die Filterung über Quarzsand'], correct: 0 },
    { q: 'Wie hängen Karbonathärte und Wassertemperatur zusammen?', a: ['Bei steigender Temperatur fällt Kalk aus (Karbonathärte sinkt)', 'Temperatur hat keinen Einfluss auf die Wasserhärte', 'Bei steigender Temperatur steigt die Karbonathärte', 'Nur bei Frost unter 0°C ändert sich die Härte'], correct: 0 },
