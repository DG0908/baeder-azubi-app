    { q: 'Wo werden neutrale Reiniger eingesetzt?', a: ['Auf empfindlichen Oberflächen, bei der täglichen Unterhaltsreinigung', 'Nur gegen starke Verschmutzungen wie Kalk und Fett', 'Nur in der Küche und dem Gastronomiebereich', 'Nur im Außenbereich bei der Fassadenreinigung'], correct: 0 },
    { q: 'Wie wirken saure Reiniger?', a: ['Sie lösen Kalk und mineralische Ablagerungen auf', 'Sie lösen Fette auf durch Verseifung', 'Sie desinfizieren durch oxidative Wirkung', 'Sie neutralisieren Gerüche durch Adsorption'], correct: 0 },
    { q: 'Wie wirken basische Reiniger?', a: ['Sie lösen Fette und organische Verschmutzungen', 'Sie lösen Kalk durch saure Reaktion auf', 'Sie desinfizieren nur durch Abtöten von Keimen', 'Sie polieren Oberflächen durch Schleifwirkung'], correct: 0 },
    { q: 'Wie wirken neutrale Reiniger?', a: ['Schonende Reinigung durch Tenside ohne aggressive pH-Wirkung', 'Stark ätzend durch hohe Konzentration an Säuren', 'Stark kalkauflösend durch niedrigen pH-Wert', 'Stark desinfizierend durch oxidative Wirkstoffe'], correct: 0 },
