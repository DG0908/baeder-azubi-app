    { q: 'Was versteht man unter Korrosion?', a: ['Zerstörung von Werkstoffen durch chemische oder elektrochemische Reaktion mit der Umgebung', 'Reinigung von Metallen durch Beizen mit Säuren', 'Verstärkung von Materialien durch Legierungsbildung', 'Lackierung von Oberflächen als Schutzmaßnahme'], correct: 0 },
    { q: 'Welche Korrosionsarten werden unterschieden?', a: ['Chemische, elektrochemische und biologische Korrosion', 'Nur Rost – alle Korrosion ist Rosten', 'Nur Lochfraß an Edelstahlbauteilen', 'Nur Flächenkorrosion an unedle Metallteilen'], correct: 0 },
    { q: 'Wie entsteht chemische Korrosion?', a: ['Durch direkte Reaktion des Metalls mit aggressiven Stoffen (Säuren, Laugen, Gase)', 'Nur durch elektrischen Strom zwischen zwei Metallen', 'Nur durch stehendes Wasser ohne Sauerstoff', 'Nur durch sehr hohe Temperaturen über 500°C'], correct: 0 },
    { q: 'Wie kann es zur Korrosion an Werkstoffen kommen?', a: ['Durch Feuchtigkeit, aggressive Chemikalien, Kontakt verschiedener Metalle', 'Nur durch intensive Sonneneinstrahlung und UV-Licht', 'Nur durch extreme Kälte unter dem Gefrierpunkt', 'Korrosion tritt nur an Eisen auf – Edelstahl ist völlig immun'], correct: 0 },
    { q: 'Wie entsteht elektrochemische Korrosion?', a: ['Durch ein galvanisches Element (zwei verschiedene Metalle in einem Elektrolyt)', 'Durch UV-Sonnenlicht auf der Metalloberfläche', 'Durch Hitze allein bei sehr hohen Temperaturen', 'Durch Wind und mechanischen Abrieb der Oberfläche'], correct: 0 },
    { q: 'Was bedeutet aktiver Korrosionsschutz?', a: ['Kathodischer Schutz durch Opferanoden oder Fremdstrom', 'Nur Anstreichen mit Rostschutzfarbe', 'Nur Abdecken mit einer Plane', 'Kein Schutz nötig – modernes Stahl rostet nicht mehr'], correct: 0 },
    { q: 'Was bedeutet passiver Korrosionsschutz?', a: ['Beschichtungen, Lackierungen, Verzinkung als Barriere', 'Elektrischer Schutz durch Opferanoden (das ist aktiver Schutz)', 'Chemischer Zusatz im Wasser als Korrosionsinhibitor', 'Keine Maßnahme – Edelstahl schützt sich selbst'], correct: 0 },
    { q: 'Was bedeutet konstruktiver Korrosionsschutz?', a: ['Vermeidung von Korrosion durch geeignete Materialwahl und Konstruktion', 'Nur Anstreichen mit Schutzlack', 'Nur Opferanoden als elektrolytischer Schutz', 'Nur Verzinkung der Metalloberflächen'], correct: 0 },
    { q: 'Wie können Sie einen Filter von innen vor Korrosion schützen?', a: ['Innenbeschichtung mit GFK oder Gummierung', 'Gar nicht – Filter aus Stahl rosten immer', 'Nur von außen streichen mit Rostschutzfarbe', 'Durch höhere Wassertemperatur um den Kalkschutz zu stärken'], correct: 0 },
    { q: 'Welche Bedeutung hat die Spannungsreihe der Metalle für die Korrosion?', a: ['Unedle Metalle korrodieren bei Kontakt mit edleren Metallen', 'Keine Bedeutung – alle Metalle korrodieren gleich schnell', 'Nur für die Elektrotechnik zur Batterieherstellung wichtig', 'Nur für Gold und Platin relevant – unedle Metalle sind betroffen'], correct: 0 },
    { q: 'Welche Vor- und Nachteile hat eine GFK-Innenbeschichtung bei Filtern?', a: ['Vorteil: korrosionsbeständig; Nachteil: kann bei Beschädigung unterwandert werden', 'Nur Vorteile – GFK ist das beste Material ohne Einschränkungen', 'Nur Nachteile – GFK ist teuer und schwer zu verarbeiten', 'Weder Vor- noch Nachteile – GFK ist neutral'], correct: 0 },
