    { q: 'Wie wirkt sich Regen auf das Wasser im Freibad aus?', a: ['Es verbessert die Wasserqualität durch Frischwasser', 'Nur positiv durch natürliche Frischwasserzufuhr', 'Verdünnung, pH-Änderung, erhöhter Schmutzeintrag', 'Es erwärmt das Beckenwasser durch Wärmeeinstrahlung'], correct: 2 },
