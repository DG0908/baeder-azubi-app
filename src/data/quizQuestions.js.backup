    { q: 'Was sind Tenside (WAS)?', a: ['Waschaktive Substanzen, die die Oberflächenspannung herabsetzen', 'Wasseraktive Salze zur Wasserhärtekorrektur', 'Wasserabweisende Stoffe als Imprägniermittel', 'Wärmeaktivierende Substanzen als Katalysatoren'], correct: 0 },
    { q: 'Warum muss das Zusammenkommen von Beckenwasser und Flächenreinigern verhindert werden?', a: ['Es können giftige Gase (z.B. Chlorgas) entstehen', 'Es passiert nichts – das Wasser verdünnt den Reiniger nur', 'Es riecht nur unangenehm – gesundheitlich unbedenklich', 'Das Beckenwasser wird nur leicht trüb'], correct: 0 },
