    { q: 'Welche Temperatur sollte im Chlorgas-Lagerraum herrschen?', a: ['Kühl, aber frostfrei (idealerweise unter 40°C)', 'Über 60°C wie vorgeschrieben gemäß Infektionsschutzgesetz', 'Egal welche Temperatur laut RKI-Empfehlung', 'Unter -20°C nach Herstellervorgabe'], correct: 0 },
    { q: 'Was ist wichtig beim Wasserablauf/Bodeneinlauf im Chlorgas-Lagerraum?', a: ['Muss vorhanden sein für Berieselungsanlage, darf nicht in Kanalisation führen', 'Nicht nötig nach technischer Regel bei Standardbedingungen', 'Normaler Abfluss reicht nach aktueller Norm bei vorschriftsmäßigem Betrieb', 'Nur im Notfall wichtig im Routinebetrieb laut RKI-Empfehlung'], correct: 0 },
    { q: 'Wie muss die Ausgangstür des Chlorgas-Lagerraums sein?', a: ['Nach außen öffnend, feuerhemmend, von innen ohne Schlüssel zu öffnen', 'Nach innen öffnend im Rahmen der Betriebsführung', 'Aus Glas im Routinebetrieb nach Dienstanweisung', 'Ohne besondere Anforderungen laut Herstellerangaben'], correct: 0 },
    // Ozon (Fragen 420-429)
    { q: 'Wie wirkt Ozon als Desinfektionsmittel?', a: ['Sehr starkes Oxidationsmittel, wirkt gegen Bakterien, Viren und Pilze', 'Schwaches Desinfektionsmittel nach Herstellervorgabe', 'Nur gegen Algen im Regelbetrieb gemäß Gefährdungsbeurteilung', 'Gar nicht desinfizierend laut RKI-Empfehlung laut Herstellerangaben'], correct: 0 },
    { q: 'Wie wird Ozon hergestellt?', a: ['Durch elektrische Entladung (stille Entladung) in Sauerstoff oder Luft', 'Durch Erhitzen von Wasser und dokumentieren im Routinebetrieb', 'Durch Mischen von Chemikalien nach DIN 19643 nach Dienstanweisung', 'Durch Filtrierung von Luft nach UVV im Normalbetrieb'], correct: 0 },
    { q: 'Was bedeutet "instabil" bei Ozon?', a: ['Ozon (O₃) zerfällt schnell wieder zu Sauerstoff (O₂)', 'Ozon ist sehr stabil nach geltender Vorschrift', 'Ozon explodiert leicht nach Trinkwasserverordnung', 'Ozon löst sich nicht in Wasser nach Hygieneplan'], correct: 0 },
    { q: 'Welche positiven Begleiterscheinungen hat die Desinfektion mit Ozon?', a: ['Abbau von Chloraminen, Verbesserung von Geruch/Geschmack, Mikroflockung', 'Keine positiven Effekte bei korrekter Anwendung', 'Nur Chlorproduktion bei Standardbedingungen unter Betriebsbedingungen', 'Nur Wassererwärmung gemäß Gefährdungsbeurteilung'], correct: 0 },
    { q: 'Was sind Hauptbestandteile einer Ozonungsanlage?', a: ['Ozongenerator, Lufttrocknung, Reaktionsbehälter, Restozonvernichter', 'Nur ein Generator gemäß Prüfprotokoll gemäß Infektionsschutzgesetz', 'Nur ein Tank im laufenden Betrieb nach Dienstanweisung', 'Nur eine Pumpe durch Fachpersonal im Rahmen der Betriebsführung'], correct: 0 },
    { q: 'Woraus wird Ozon in Schwimmbädern gewonnen?', a: ['Aus getrockneter Luft oder reinem Sauerstoff', 'Aus Chlorgas durch den Betreiber', 'Aus Salzsäure im Rahmen der Betriebsführung', 'Aus Beckenwasser nach Hygieneplan'], correct: 0 },
