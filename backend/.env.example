# Server
PORT=3001

# Frontend URL(s) fuer CORS
FRONTEND_URL=https://azubi.smartbaden.de
CORS_ORIGINS=https://azubi.smartbaden.de,https://www.azubi.smartbaden.de

# Supabase (self-hosted)
SUPABASE_URL=https://db.smartbaden.de
SUPABASE_ANON_KEY=dein_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=dein_supabase_service_role_key

# Web Push VAPID Keys (generieren mit: npx web-push generate-vapid-keys)
WEB_PUSH_PUBLIC_KEY=dein_vapid_public_key
WEB_PUSH_PRIVATE_KEY=dein_vapid_private_key
WEB_PUSH_SUBJECT=mailto:noreply@smartbaden.de
