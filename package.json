{
  "name": "baeder-azubi-app",
  "version": "1.0.0",
  "description": "Lern-App für Fachangestellte für Bäderbetriebe",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check:questions": "node scripts/validate-questions.mjs",
    "smoke:api": "node scripts/run-smoke-checks.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check \"src/**/*.{js,jsx,json,css}\"",
    "format:fix": "prettier --write \"src/**/*.{js,jsx,json,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "echo 'TODO: TypeScript-Migration ausstehend — siehe docs/marktreife-roadmap.md P2.9' && exit 1",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/drei": "^9.121.4",
    "@react-three/fiber": "^8.17.14",
    "@tanstack/react-query": "^5.99.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.14.1",
    "three": "^0.160.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.11.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.32",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.6",
    "typescript": "^6.0.3",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^0.19.8",
    "vitest": "^2.1.9",
    "vitest-axe": "^0.1.0",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  }
}
