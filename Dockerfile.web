FROM node:20-alpine AS build
WORKDIR /app

ARG VITE_API_BASE_URL=/api
ARG VITE_SUPABASE_URL
ARG VITE_SUPABASE_ANON_KEY
ARG VITE_ENABLE_UNSAFE_LEGACY_DB_WRITES=false
ARG VITE_ENABLE_SECURE_BACKEND_API=true
ARG VITE_WEB_PUSH_PUBLIC_KEY=
ARG VITE_PUSH_FUNCTION_NAME=send-web-push
ARG VITE_PUSH_BACKEND_URL=

ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ENV VITE_SUPABASE_URL=${VITE_SUPABASE_URL}
ENV VITE_SUPABASE_ANON_KEY=${VITE_SUPABASE_ANON_KEY}
ENV VITE_ENABLE_UNSAFE_LEGACY_DB_WRITES=${VITE_ENABLE_UNSAFE_LEGACY_DB_WRITES}
ENV VITE_ENABLE_SECURE_BACKEND_API=${VITE_ENABLE_SECURE_BACKEND_API}
ENV VITE_WEB_PUSH_PUBLIC_KEY=${VITE_WEB_PUSH_PUBLIC_KEY}
ENV VITE_PUSH_FUNCTION_NAME=${VITE_PUSH_FUNCTION_NAME}
ENV VITE_PUSH_BACKEND_URL=${VITE_PUSH_BACKEND_URL}

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.27-alpine
COPY docker/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
