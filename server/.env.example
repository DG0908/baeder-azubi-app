NODE_ENV=development
APP_PORT=3000
APP_CORS_ORIGINS=http://localhost:5173
APP_COOKIE_DOMAIN=
APP_COOKIE_SECURE=false
DATABASE_URL=postgresql://azubi_app:change_me@localhost:5432/azubi_app?schema=public
JWT_ACCESS_SECRET=replace_with_at_least_32_characters
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=replace_with_at_least_32_characters
JWT_REFRESH_TTL=7d
INVITATION_CODE_PEPPER=replace_with_at_least_32_characters
PASSWORD_RESET_TOKEN_PEPPER=replace_with_at_least_32_characters
PASSWORD_RESET_TTL=30m
APP_PUBLIC_URL=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@example.de
DUEL_DEFAULT_QUESTION_COUNT=20
DUEL_REQUEST_TTL_MINUTES=2880
DUEL_TURN_TTL_MINUTES=2880
LOG_LEVEL=log,warn,error
APP_TOTP_ENCRYPTION_KEY=         # 32+ char random string — required to enable 2FA setup
